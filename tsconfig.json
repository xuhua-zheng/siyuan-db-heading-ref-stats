{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "noImplicitAny": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "allowArbitraryExtensions": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
